def handleVoiceState(*Connection conn, object msg) object (
  string id = getUserId(conn)
  if !isAuthenticated(conn) (
    return authErrorMsg("Authentication required")
  )
  if !checkReadRequestLimit(conn) (
    return { cmd: "error", val: "Rate limit exceeded. Please slow down." }
  )

  string channel = msg.channel.toStr()
  if channel == "" (
    return { cmd: "error", val: "Channel is required" }
  )
  if !verifyChannelMemberNoSend(id, channel) (
    return { cmd: "error", val: "You are not a member of this channel" }
  )

  any currentVc = conn.Get("voice_channel")
  bool inChannel = currentVc != null and currentVc.toStr() == channel

  array participants = getVoiceParticipants(channel, id, inChannel)

  return {
    cmd: "voice_state",
    channel: channel,
    participants: participants
  }
)

// getVoiceParticipants returns a list of participants for a voice channel.
// excludeId: user to exclude (self on join). includePeerId: whether to include peer_id.
def getVoiceParticipants(string channel, string excludeId, bool includePeerId) array (
  array result = []
  if typeof(voiceChannels[channel]) != "object" (
    return result
  )
  object vcData = voiceChannels[channel].assert(object)
  // Iterate all connected clients and check if they are in this voice channel
  any connections = server.GetConnections()
  for i connections.len (
    "*Connection" memberConn = connections[i].assert(*Connection)
    any connId = memberConn.Get("id")
    if connId == null or connId.toStr() == "" (
      continue
    )
    string memberId = connId.toStr()
    if memberId == excludeId (
      continue
    )
    any memberVc = memberConn.Get("voice_channel")
    if memberVc == null or memberVc.toStr() != channel (
      continue
    )
    if typeof(vcData[memberId]) != "object" (
      continue
    )
    object entry = vcData[memberId].assert(object)
    object participant = {
      id: memberId,
      username: entry.username.toStr(),
      muted: entry.muted.toBool()
    }
    if includePeerId (
      participant.peer_id = entry.peer_id.toStr()
    )
    result.append(participant)
  )
  return result
)

def broadcastUserConnect(string id, string username, array channels) (
    object connectMsg = {
        cmd: "user_connect",
        user: {
            username: username,
            roles: ["user"] ++ channels,
            color: null
        }
    }
    any connections = server.GetConnections()
    for i connections.len (
        "*Connection" memberConn = connections[i].assert(*Connection)
        any connId = memberConn.Get("id")
        if connId == null or connId.toStr() == "" (
            continue
        )
        if connId.toStr() == id (
            continue
        )
        object memberUser = getUser(connId.toStr())
        if typeof(memberUser.channels) == "array" (
            array memberChannels = memberUser.channels
            bool sharesChannel = false
            for j memberChannels.len (
                if channels.contains(memberChannels[j].toStr()) (
                    sharesChannel = true
                    break
                )
            )
            if sharesChannel (
                memberConn.Send(connectMsg)
            )
        )
    )
)

def broadcastUserDisconnect(string id) (
    if id == "" (
        return
    )
    string username = getUsernameById(id)
    if username == "" (
        return
    )
    object disconnectMsg = {
        cmd: "user_disconnect",
        username: username
    }
    object user = getUser(id)
    array channels = []
    if typeof(user.channels) == "array" (
        channels = user.channels
    )
    any connections = server.GetConnections()
    for i connections.len (
        "*Connection" memberConn = connections[i].assert(*Connection)
        any connId = memberConn.Get("id")
        if connId == null or connId.toStr() == "" (
            continue
        )
        if connId.toStr() == id (
            continue
        )
        object memberUser = getUser(connId.toStr())
        if typeof(memberUser.channels) == "array" (
            array memberChannels = memberUser.channels.assert(array)
            bool sharesChannel = false
            for j memberChannels.len (
                if channels.contains(memberChannels[j].toStr()) (
                    sharesChannel = true
                    break
                )
            )
            if sharesChannel (
                memberConn.Send(disconnectMsg)
            )
        )
    )
)