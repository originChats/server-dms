import "osl/ws"
import "osl/requests"
import "osl/fs"
import "osl/lock"
import "osl/crypto"
import "osl/webpush"
import "osl/arrays"
import "osl/cmd"

import "./messages.osl"
import "./db.osl"
import "./push/db.osl"
import "./push/handlers.osl"
import "./handlers.osl"

"*Server" server = nil

object users = {}
object userConnections = {}

// voiceChannels: channelId -> { userId -> { peer_id, username, muted } }
object voiceChannels = {}

def newConnection(*Connection conn) (
    log "New connection"
    string validatorKey = "originChats-" ++ randomString(32)
    conn.Set("validator_key", validatorKey)
    conn.Send({
        "cmd": "handshake",
        "val": {
            server: {
                name: "DMs",
                icon: "https://originchats.mistium.com/dms.png",
                type: "direct",
                url: "wss://dms.mistium.com",
                owner: {
                    name: "Mist"
                }
            },
            limits: {
                post_content: 2000
            },
            version: "1.1.0",
            validator_key: validatorKey,
            capabilities: [
                "auth",
                "channels_get",
                "dm_create",
                "message_delete",
                "message_edit",
                "message_new",
                "message_pin",
                "message_react_add",
                "message_react_remove",
                "message_unpin",
                "messages_get",
                "messages_pinned",
                "messages_around",
                "typing",
                "users_list",
                "users_online",
                "voice_join",
                "voice_leave",
                "voice_mute",
                "voice_state",
                "voice_unmute",
                "message_replies",
                "push_get_vapid",
                "push_subscribe",
                "push_unsubscribe"
            ]
        }
    })
)

def handleMessage(*Connection conn, string message) (
  any rawMsg = message.JsonParse()

  if typeof(rawMsg) != "object" (
    return
  )
  object msg = rawMsg.assert(object)

  string listener = ""
  if typeof(msg.listener) == "string" (
    listener = msg.listener.toStr()
  )

  string cmd = msg.cmd.toStr()
  any response = null

  switch cmd (
  case "auth"
    response = handleAuth(conn, msg)
  case "channels_get"
    response = handleChannelsGet(conn)
  case "users_list"
    response = handleUsersList(conn, msg)
  case "users_online"
    response = handleUsersOnline(conn, msg)
  case "messages_get"
    response = handleMessagesGet(conn, msg)
  case "messages_around"
    response = handleMessagesAround(conn, msg)
  case "message_new"
    response = handleMessageNew(conn, msg)
  case "message_replies"
    response = handleMessageReplies(conn, msg)
  case "message_edit"
    response = handleMessageEdit(conn, msg)
  case "message_delete"
    response = handleMessageDelete(conn, msg)
  case "message_react_add"
    response = handleMessageReactAdd(conn, msg)
  case "message_react_remove"
    response = handleMessageReactRemove(conn, msg)
  case "message_pin"
    response = handleMessagePin(conn, msg)
  case "message_unpin"
    response = handleMessageUnpin(conn, msg)
  case "messages_pinned"
    response = handleMessagesPinned(conn, msg)
  case "dm_create"
    response = handleDMCreate(conn, msg)
  case "typing"
    response = handleTyping(conn, msg)
  case "voice_join"
    response = handleVoiceJoin(conn, msg)
  case "voice_leave"
    response = handleVoiceLeave(conn, msg)
  case "voice_mute"
    response = handleVoiceMute(conn, msg)
  case "voice_unmute"
    response = handleVoiceUnmute(conn, msg)
  case "voice_state"
    response = handleVoiceState(conn, msg)
  case "push_get_vapid"
    response = handlePushGetVapid(conn)
  case "push_subscribe"
    response = handlePushSubscribe(conn, msg)
  case "push_unsubscribe"
    response = handlePushUnsubscribe(conn, msg)
  default
    response = { cmd: "error", val: "Unknown command: " ++ cmd }
  )

  if typeof(response) != "object" (
    return
  )

  object responseObj = response.assert(object)

  if listener != "" (
    response.listener = listener
  )

  if responseObj.global.toBool() (
    string channel = responseObj.channel.toStr()
    if channel != "" (
      sendMessageToAllUsersInChannel(conn, channel, responseObj)
    )
    return
  )
  
  conn.Send(response)
)

def closeConnection(*Connection conn) (
    string id = getUserId(conn)
    string username = getUsername(conn)
    log "Connection closed for " ++ username
    users.delete(conn)
    if id != "" (
        lock.Lock("userConnections")
        userConnections.delete(id)
        lock.Unlock("userConnections")
        // Clean up voice state if user was in a voice channel
        any voiceChannel = conn.Get("voice_channel")
        if voiceChannel != null and voiceChannel.toStr() != "" (
            string vcName = voiceChannel.toStr()
            cleanupVoiceOnDisconnect(conn, id, username, vcName)
        )
        broadcastUserDisconnect(id)
    )
)

def startPingTimer() (
    while true (
        wait 60
        server.Broadcast({
            cmd: "ping"
        }.JsonStringify())
    )
)

def sendMessageToVoiceChannelMembers(string channelId, object message) (
    object ch = getChannel(channelId)
    if ch == null or typeof(ch.members) != "array" (
        return
    )
    array members = ch.members.assert(array)
    any connections = server.GetConnections()
    for i connections.len (
        "*Connection" memberConn = connections[i].assert(*Connection)
        any connId = memberConn.Get("id")
        if connId == null or connId.toStr() == "" (
            continue
        )
        if !members.contains(connId.toStr()) (
            continue
        )
        memberConn.Send(message)
    )
)

def cleanupVoiceOnDisconnect(*Connection conn, string id, string username, string vcName) (
    if typeof(voiceChannels[vcName]) != "object" (
        return
    )
    object vcData = voiceChannels[vcName].assert(object)
    vcData.delete(id)
    if vcData.len == 0 (
        voiceChannels.delete(vcName)
    ) else (
        voiceChannels[vcName] = vcData
    )
    object leaveMsg = {
        cmd: "voice_user_left",
        channel: vcName,
        username: username
    }
    sendMessageToVoiceChannelMembers(vcName, leaveMsg)
)

mainloop:

    fs.Mkdir("db")
    fs.Mkdir("db/users")
    fs.Mkdir("db/channels")
    fs.Mkdir("db/channel_messages")

    migrateChannelMessagesForAllChannels()

    server = ws.NewServer(":5618", "/")

    server.OnConnect(newConnection)
    server.OnMessage(handleMessage)
    server.OnDisconnect(closeConnection)

    go startPingTimer()
    server.Start()